# Example SMTP configuration for sending OTP emails
# Replace with your SMTP provider values (e.g., SendGrid, Mailgun, SMTP from your mail provider)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
FROM_EMAIL=you@yourdomain.com

# Optional: server port
PORT=4000

# Email provider: use smtp for Gmail/App Password sending without a domain,
# resend for Resend domain-based sending, or leave blank to auto-detect.
EMAIL_PROVIDER=smtp

# Frontend URL for deployed CORS access
# For multiple URLs, use commas:
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://www.yourdomain.com
CLIENT_ORIGIN=http://localhost:5173

# Gmail SMTP example. Create an App Password in your Google Account.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=yourgmail@gmail.com
# SMTP_PASS=your_google_app_password
# FROM_EMAIL=yourgmail@gmail.com

# MongoDB Atlas connection string
MONGO_URI=your_mongodb_connection_string_here

# Optional: use Resend API for real OTP emails
# RESEND_API_KEY=your_resend_api_key
# RESEND_FROM_EMAIL=AETHRIX AI <onboarding@resend.dev>

# Groq API configuration
GROQ_API_KEY=your_groq_api_key_here
